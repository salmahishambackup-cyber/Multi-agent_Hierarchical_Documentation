{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AST Output Schema",
  "type": "object",
  "patternProperties": {
    ".*": {
      "type": "object",
      "required": ["file", "language"],
      "properties": {
        "file": {
          "type": "string",
          "description": "Relative path to the file"
        },
        "language": {
          "type": "string",
          "description": "Programming language"
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "functions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
