{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dependency Graph Schema",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file"],
        "properties": {
          "id": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["internal_module", "cross_language", "uncertain_dynamic", "external_library", "language_runtime"]
          }
        }
      }
    }
  }
}
