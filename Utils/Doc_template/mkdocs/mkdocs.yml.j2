site_name: {{ site_name }}
theme:
  name: material
  features:
    - navigation.instant
    - navigation.sections
    - navigation.tracking
    - content.code.copy
    - search.suggest
    - search.highlight
plugins:
  - search

nav:
  - Home: index.md
  - Getting Started: getting-started.md
  - Architecture:
      - Overview: architecture/overview.md
      - Dependencies: architecture/dependencies.md
  - API Reference:
{% for item in nav_api %}
      - {{ item.title }}: {{ item.path }}
{% endfor %}