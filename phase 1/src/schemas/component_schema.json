{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "High-level Code Components",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "component_id",
      "hypothesis",
      "files",
      "evidence",
      "confidence"
    ],
    "properties": {
      "component_id": {
        "type": "string"
      },
      "hypothesis": {
        "type": "string"
      },
      "files": {
        "type": "array",
        "items": { "type": "string" }
      },
      "evidence": {
        "type": "array",
        "items": { "type": "string" }
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  }
}
