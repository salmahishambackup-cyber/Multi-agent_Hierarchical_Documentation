{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Structure Schema",
  "type": "object",
  "required": ["repo", "root_module"],
  "properties": {
    "repo": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "root_module": {
      "$ref": "#/definitions/module"
    }
  },
  "definitions": {
    "module": {
      "type": "object",
      "required": ["module_id", "name", "files", "children"],
      "properties": {
        "module_id": {
          "type": "string",
          "pattern": "^MOD_[0-9]{4}$"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/module"
          }
        }
      }
    }
  }
}

